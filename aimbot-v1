pcall(function()
	getgenv().aimbot_environment.functions:exit()
end)

getgenv().aimbot_environment = {}
local environment = getgenv().aimbot_environment

local run_service = game:GetService("RunService")
local user_input_service = game:GetService("UserInputService")
local http_service = game:GetService("HttpService")
local tween_service = game:GetService("TweenService")
local starter_gui = game:GetService("StarterGui")
local players = game:GetService("Players")
local camera = game:GetService("Workspace").CurrentCamera

local local_player = players.LocalPlayer
local folder_name = "Exunys Developer"
local files = {"Aimbot", "Configuration.json", "Drawing.json"}
local is_typing = false
local is_running = false
local lock_animation = nil
local max_distance = 2000
local connections = {}

local mouse_move = mousemoverel or (Input and Input.MouseMove)
local teleport_queue = queue_on_teleport or syn.queue_on_teleport

environment.settings = {
	send_notifications = true,
	save_settings = true,
	reload_on_teleport = true,
	enabled = true,
	team_check = false,
	alive_check = true,
	wall_check = false,
	sensitivity = 0,
	third_person = false,
	third_person_sensitivity = 3,
	trigger_key = "MouseButton2",
	exit_key = Enum.KeyCode.P,
	toggle = false,
	lock_part = "Head"
}

environment.fov_settings = {
	enabled = true,
	visible = true,
	amount = 90,
	color = "255, 255, 255",
	locked_color = "255, 70, 70",
	transparency = 0.5,
	sides = 60,
	thickness = 1,
	filled = false
}

environment.fov_circle = Drawing.new("Circle")
environment.locked_target = nil

local function json_encode(data)
	if data and type(data) == "table" then
		return http_service:JSONEncode(data)
	end
end

local function json_decode(data)
	if data and type(data) == "string" then
		return http_service:JSONDecode(data)
	end
end

local function parse_color(color_string)
	local r = tonumber(string.match(color_string, "([%d]+)[%s]*,[%s]*[%d]+[%s]*,[%s]*[%d]+"))
	local g = tonumber(string.match(color_string, "[%d]+[%s]*,[%s]*([%d]+)[%s]*,[%s]*[%d]+"))
	local b = tonumber(string.match(color_string, "[%d]+[%s]*,[%s]*[%d]+[%s]*,[%s]*([%d]+)"))
	return Color3.fromRGB(r, g, b)
end

local function notify(title_text, description, time)
	if environment.settings.send_notifications then
		starter_gui:SetCore("SendNotification", {
			Title = title_text,
			Text = description,
			Duration = time
		})
	end
end

local function save_to_file()
	if environment.settings.save_settings then
		local path = folder_name .. "/" .. files[1] .. "/"
		if isfile(path .. files[2]) then
			writefile(path .. files[2], json_encode(environment.settings))
		end
		if isfile(path .. files[3]) then
			writefile(path .. files[3], json_encode(environment.fov_settings))
		end
	end
end

local function find_target()
	if not environment.locked_target then
		max_distance = environment.fov_settings.enabled and environment.fov_settings.amount or 2000

		for _, player in next, players:GetPlayers() do
			if player ~= local_player then
				local char = player.Character
				local part = char and char:FindFirstChild(environment.settings.lock_part)
				local hum = char and char:FindFirstChildOfClass("Humanoid")

				if char and part and hum then
					if environment.settings.team_check and player.Team == local_player.Team then continue end
					if environment.settings.alive_check and hum.Health <= 0 then continue end
					if environment.settings.wall_check and #(camera:GetPartsObscuringTarget({part.Position}, char:GetDescendants())) > 0 then continue end

					local pos, on_screen = camera:WorldToViewportPoint(part.Position)
					local mouse_pos = user_input_service:GetMouseLocation()
					local distance = (Vector2.new(mouse_pos.X, mouse_pos.Y) - Vector2.new(pos.X, pos.Y)).Magnitude

					if distance < max_distance and on_screen then
						max_distance = distance
						environment.locked_target = player
					end
				end
			end
		end
	else
		local part = environment.locked_target.Character[environment.settings.lock_part]
		local pos = camera:WorldToViewportPoint(part.Position)
		local mouse_pos = user_input_service:GetMouseLocation()
		local current_dist = (Vector2.new(mouse_pos.X, mouse_pos.Y) - Vector2.new(pos.X, pos.Y)).Magnitude

		if current_dist > max_distance then
			environment.locked_target = nil
			if lock_animation then lock_animation:Cancel() end
			environment.fov_circle.Color = parse_color(environment.fov_settings.color)
		end
	end
end

connections.typing_start = user_input_service.TextBoxFocused:Connect(function()
	is_typing = true
end)

connections.typing_end = user_input_service.TextBoxFocusReleased:Connect(function()
	is_typing = false
end)

if environment.settings.save_settings then
	local root = folder_name
	local sub = folder_name .. "/" .. files[1]
	if not isfolder(root) then makefolder(root) end
	if not isfolder(sub) then makefolder(sub) end

	if not isfile(sub .. "/" .. files[2]) then
		writefile(sub .. "/" .. files[2], json_encode(environment.settings))
	else
		environment.settings = json_decode(readfile(sub .. "/" .. files[2]))
	end

	if not isfile(sub .. "/" .. files[3]) then
		writefile(sub .. "/" .. files[3], json_encode(environment.fov_settings))
	else
		environment.fov_settings = json_decode(readfile(sub .. "/" .. files[3]))
	end

	coroutine.wrap(function()
		while task.wait(10) and environment.settings.save_settings do
			save_to_file()
		end
	end)()
end

local function run_logic()
	connections.render = run_service.RenderStepped:Connect(function()
		if environment.fov_settings.enabled and environment.settings.enabled then
			local fov = environment.fov_circle
			local config = environment.fov_settings
			local mouse = user_input_service:GetMouseLocation()

			fov.Radius = config.amount
			fov.Thickness = config.thickness
			fov.Filled = config.filled
			fov.NumSides = config.sides
			fov.Color = parse_color(config.color)
			fov.Transparency = config.transparency
			fov.Visible = config.visible
			fov.Position = Vector2.new(mouse.X, mouse.Y)
		else
			environment.fov_circle.Visible = false
		end

		if is_running and environment.settings.enabled then
			find_target()

			if environment.locked_target then
				local part = environment.locked_target.Character[environment.settings.lock_part]
				if environment.settings.third_person then
					local pos = camera:WorldToViewportPoint(part.Position)
					local mouse = user_input_service:GetMouseLocation()
					mouse_move((pos.X - mouse.X) * environment.settings.third_person_sensitivity, (pos.Y - mouse.Y) * environment.settings.third_person_sensitivity)
				else
					if environment.settings.sensitivity > 0 then
						lock_animation = tween_service:Create(camera, TweenInfo.new(environment.settings.sensitivity, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {CFrame = CFrame.new(camera.CFrame.Position, part.Position)})
						lock_animation:Play()
					else
						camera.CFrame = CFrame.new(camera.CFrame.Position, part.Position)
					end
				end
				environment.fov_circle.Color = parse_color(environment.fov_settings.locked_color)
			end
		end
	end)

	connections.input_start = user_input_service.InputBegan:Connect(function(input)
		if is_typing then return end

		if input.KeyCode == environment.settings.exit_key then
			environment.functions:exit()
		end

		local trigger = environment.settings.trigger_key
		if input.KeyCode == Enum.KeyCode[trigger] or input.UserInputType == Enum.UserInputType[trigger] then
			if environment.settings.toggle then
				is_running = not is_running
				if not is_running then
					environment.locked_target = nil
					if lock_animation then lock_animation:Cancel() end
					environment.fov_circle.Color = parse_color(environment.fov_settings.color)
				end
			else
				is_running = true
			end
		end
	end)

	connections.input_end = user_input_service.InputEnded:Connect(function(input)
		if is_typing then return end
		local trigger = environment.settings.trigger_key
		if not environment.settings.toggle then
			if input.KeyCode == Enum.KeyCode[trigger] or input.UserInputType == Enum.UserInputType[trigger] then
				is_running = false
				environment.locked_target = nil
				if lock_animation then lock_animation:Cancel() end
				environment.fov_circle.Color = parse_color(environment.fov_settings.color)
			end
		end
	end)
end

environment.functions = {}

function environment.functions:exit()
	save_to_file()
	for _, connection in next, connections do
		connection:Disconnect()
	end
	if environment.fov_circle then
		environment.fov_circle.Visible = false
		environment.fov_circle:Remove()
	end
	getgenv().aimbot_environment = nil
end

function environment.functions:restart()
	for _, connection in next, connections do
		connection:Disconnect()
	end
	run_logic()
end

if not Drawing then
	notify(folder_name, "Your exploit does not support Drawing API", 3)
	return
end

run_logic()
notify(folder_name, "Aimbot loaded. Press P to fully exit.", 5)
